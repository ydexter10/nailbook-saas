# Variáveis de Ambiente — NailBook Backend
# ⚠️ NUNCA commitar este arquivo! Copie para .env e preencha os valores.

# ─── SEGURANÇA ────────────────────────────────────
# Gere uma string aleatória longa: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=TROQUE_ISSO_POR_UMA_STRING_ALEATORIA_LONGA

# ─── BANCO DE DADOS (Vercel Postgres / Neon) ────────
# Preenchido automaticamente pelo Vercel ao integrar o Postgres
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── SERVIDOR ─────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS (produção) ──────────────────────────────
# Coloque a URL do seu app Vercel (sem barra no final)
CORS_ORIGIN=https://nailbook-saas-942p.vercel.app
