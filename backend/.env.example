# Variáveis de Ambiente — NailBook Backend
# ⚠️ NUNCA commitar este arquivo! Copie para .env e preencha os valores.

# ─── SEGURANÇA ────────────────────────────────────
# Gere uma string aleatória longa: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=TROQUE_ISSO_POR_UMA_STRING_ALEATORIA_LONGA

# ─── BANCO DE DADOS ───────────────────────────────
# Desenvolvimento local (SQLite):
# DATABASE_URL="file:./dev.db"
#
# Produção (Railway PostgreSQL — copie da aba Variables do serviço PostgreSQL):
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── SERVIDOR ─────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS (produção) ──────────────────────────────
# Coloque a URL do seu app Vercel (sem barra no final)
# Separe múltiplas origens com vírgula
CORS_ORIGIN=https://nailbook.vercel.app
